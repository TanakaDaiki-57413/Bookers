22:                <th>body</th>
23:                <th></th>
24:            </tr>
25:            <% @books.each do |book|%>
26:              <tr>
27:                <td><%=book.title%></td>
28:                <td><%=book.body%></td>
29:                <td class="button">
30:                  <%= link_to "Show",book_path(book.id)%>
31:                  <%= link_to "Edit",edit_book_path(book.id)%>
32:                  <%= link_to "Destroy",book_path(book.id), data: { turbo_method: :delete, turbo_confirm:"確認：本当に削除しますか？" } %> 
33:                </td>
34:              <tr>
35:            <% end%>       
36:          </table>
37:        </div>
38:        <%# 新規登録ポジション %>
39:        <div class="create_region">
40:          <%= form_with model: @book  do |f| %>
41:            <h3>New Book</h3>
42:    
43:            <%# バリデーションチェック %>
44:            <% if @book.errors.any? %>
45:              <p class="color_error">Title  ※Not Entered</p>
46:            <% else %>
47:              <p>Title</p>
48:            <%end%> 
49:    
50:            <%= f.text_field :title %>
51:    
52:            <%# バリデーションチェック %>
53:            <% if @book.errors.any? %>
54:              <p class="color_error">Body  ※Not Entered</p>
55:            <% else %>
56:              <p>Body</p>
57:            <%end%> 
58:            <%= f.text_area :body %>
59:            
60:    
61:            <br>
62:            <%= f.submit 'Create Book' %>
63:          <% end %>
64:    
65:          <%# エラーメッセージ表示 %>
66:          <div class="error_region">
67:            <% if @book.errors.any? %>
68:              <text class="color_error"><%= @book.errors.count %>errors prohibited this book from being saved:</text>
69:              <ul>
70:                <% @book.errors.full_messages.each do |message| %>
71:                <li class="margin_left_cl color_error"><%= message %></li>
72:              </ul>
73:            <% end %>
74:          </div>
75:        </div>
76:    
77:    
78:    
79:        
80:      </main>
81:    </body>
  

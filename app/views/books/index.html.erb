<body>
  <header class="index_header">
    <h1>Bookers</h1>

    <%# タイトルをクリック後一覧表示に戻る機能実装したがRSpecでエラーになるためコメント化 %>
    <%# <h1>link_to "Bookers", books_path</h1> %>

    <%# フラッシュメッセージ表示・カラー適用 %>
    <% flash.each do |message_type, message| %>
        <% if @book.errors.any? %>
          <div class="color_error <%= message_type %>"><%= message %></div>
        <%else%>
          <div class="color_succsess <%= message_type %>"><%= message %></div>
        <%end%>
    <% end %>

  </header>

  <main class="index_main">
    <%# 一覧表示ポジション %>
    <div class="list_region">
      <table class="table_region" border="1" bordercolor="black">
        <tr>
            <th>Title</th>
            <th>body</th>
            <th></th>
        </tr>
        <% @books.each do |book|%>
          <tr>
            <td><%=book.title%></td>
            <td><%=book.body%></td>
            <td class="button">
              <%= link_to "Show",book_path(book.id)%>
              <%= link_to "Edit",edit_book_path(book.id)%>
              <%= link_to "Destroy",book_path(book.id), data: { turbo_method: :delete, turbo_confirm:"確認：本当に削除しますか？" } %> 
            </td>
          <tr>
        <% end%>       
      </table>
    </div>
    <%# 新規登録ポジション %>
    <div class="create_region">
      <%= form_with model: @book  do |f| %>
        <h3>New Book</h3>

        <%# バリデーションチェック %>
        <% if @book.errors.any? %>
          <p class="color_error">Title  ※Not Entered</p>
        <% else %>
          <p>Title</p>
        <%end%> 

        <%= f.text_field :title %>

        <%# バリデーションチェック %>
        <% if @book.errors.any? %>
          <p class="color_error">Body  ※Not Entered</p>
        <% else %>
          <p>Body</p>
        <%end%> 
        <%= f.text_area :body %>
        

        <br>
        <%= f.submit 'Create Book' %>
      <% end %>

      <%# エラーメッセージ表示 %>
      <div class="error_region">
        <% if @book.errors.any? %>
          <text class="color_error"><%= @book.errors.count %>errors prohibited this book from being saved:</text>
            <ul>
              <% @book.errors.full_messages.each do |message| %>
              <li class="color_error"><%= message %></li>
            </ul>
          <% end %>
        <% end %>
      </div>
    </div>



    
  </main>
</body>
<body>
  <header class="index_header">
    <h1>Bookers</h1>
  </header>

  <main class="index_main">
    <%# 一覧表示ポジション %>
    <div class="list_region">
      <table class="table_region" border="1" bordercolor="black">
        <tr>
            <th>Title</th>
            <th>body</th>
            <th></th>
        </tr>
        <tr>
          <td class="td_title">セミナー名</td>
          <td class="td_body">1日速習HTML・CSSセミナー1日速習1日速習HTML・CSSセミナー1日速習1日速習HTML・CSSセミナー1日速習1日速習HTML・CSSセミナー1日速習1日速習HTML・CSSセミナー1日速習</td>
          <td class="button">
            <a href="#">Show</a>
            <a href="#">Edit</a>
            <a href="#">Destroy</a>
          </td>
        </tr>
        <tr>
          <td>開催日時</td>
          <td>2020年10月31日</td>
          <td class="button">
            <a href="#">Show</a>
            <a href="#">Edit</a>
            <a href="#">Destroy</a>
          </td>
        </tr>
        <tr>
          <td>開催場所</td>
          <td>大阪市内セミナールーム</td>
          <td class="button">
            <a href="#">Show</a>
            <a href="#">Edit</a>
            <a href="#">Destroy</a>
          </td>
        </tr>
        <tr>
          <td>参加費用</td>
          <td>11,000(税込)</td>
          <td class="button">
            <a href="#">Show</a>
            <a href="#">Edit</a>
            <a href="#">Destroy</a>
          </td>
        </tr>
      </table>
    </div>
    <%# 新規登録ポジション %>
    <div class="create_region">
      <%= form_with model: @book  do |f| %>
        <h3>New Book</h3>
        <p>Title</p>
        <%= f.text_field :title %>
	
        <p>body</p>
        <%= f.text_area :body %>

        <br>
        <%= f.submit '投稿' %>
      <% end %>
    </div>
  </main>
</body>
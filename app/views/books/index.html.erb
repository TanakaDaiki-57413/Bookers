<body>
  <header class="index_header">
    <h1>Bookers</h1>
  </header>

  <main class="index_main">
    <%# 一覧表示ポジション %>
    <div class="list_region">
      <table class="table_region" border="1" bordercolor="black">
        <tr>
            <th>Title</th>
            <th>body</th>
            <th></th>
        </tr>
        <% @books.each do |book|%>
          <tr>
            <td><%=book.title%></td>
            <td><%=book.body%></td>
            <td class="button">
              <%= link_to "Show",book_path(book.id)%>
              <a href="#">Edit</a>
              <a href="#">Destroy</a>
            </td>
          <tr>
        <% end%>       
      </table>
    </div>
    <%# 新規登録ポジション %>
    <div class="create_region">
      <%= form_with model: Book.new  do |f| %>
        <h3>New Book</h3>
        <p>Title</p>
        <%= f.text_field :title %>
	
        <p>body</p>
        <%= f.text_area :body %>

        <br>
        <%= f.submit '投稿' %>
      <% end %>
    </div>
  </main>
</body>